# ─── Server ───────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
MOCK_DATABASE=false

# ─── Neon Postgres (Primary production database) ─────────────────────
# Use the pooled Neon connection string and keep the real value only in
# server-sheets/.env locally or Vercel Environment Variables.
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# ─── Frontend URL (CORS) ──────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Google Sheets ────────────────────────────────────────────────────
SHEET_ID=your_google_sheet_id_here
SHEET_NAME=Booking-List3

# ─── Google Service Account ───────────────────────────────────────────
# Option A: Path to downloaded JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./your-service-account-key.json

# Option B: Inline credentials (for Vercel / cloud deploy)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Admin ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
