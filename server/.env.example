# ─────────────────────────────────────────────────────────
#  ระบบจองห้องประชุม — Environment Variables
#  คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าให้ครบ
# ─────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# URL หน้าเว็บหลัก (ใช้ใน Google Calendar source.url)
APP_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# ─── Google Calendar ──────────────────────────────────────
# calendarId ของปฏิทินกลุ่ม (ใช้ค่านี้เป็น default อยู่แล้วในโค้ด)
GOOGLE_CALENDAR_ID=cvq6279kfec56nnmsa90sq16vc@group.calendar.google.com

# ══════════════════════════════════════════════════════════
#  เลือกใช้วิธีล็อกอิน Google API วิธีใดวิธีหนึ่ง:
# ══════════════════════════════════════════════════════════

# ─── วิธีที่ 1: Service Account (แนะนำ — เหมาะกับ server) ──
#
#  1) ไปที่ https://console.cloud.google.com/
#  2) สร้างหรือเลือก Project → Enable "Google Calendar API"
#  3) IAM & Admin → Service Accounts → Create Service Account
#  4) กด Actions → Manage Keys → Add Key → JSON
#     ระบบจะดาวน์โหลดไฟล์ JSON มาให้
#  5) เปิดไฟล์ JSON แล้วคัดลอกเนื้อหาทั้งหมดใส่ในตัวแปรนี้
#     (ต้องใส่ทั้งหมดในบรรทัดเดียว หรือใช้ single-quote ใน bash)
#  6) แชร์ปฏิทิน Google Calendar ให้กับ email ของ Service Account
#     (เช่น my-sa@my-project.iam.gserviceaccount.com) ในฐานะ "Make changes to events"
#
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── วิธีที่ 2: OAuth2 Refresh Token ──────────────────────
#
#  1) Google Cloud Console → APIs & Services → Credentials
#  2) Create Credentials → OAuth 2.0 Client ID → Web application
#  3) ใส่ redirect URI: http://localhost:5000/auth/google/callback
#  4) ใช้ OAuth Playground (https://developers.google.com/oauthplayground)
#     เพื่อแลก refresh token สำหรับ scope: https://www.googleapis.com/auth/calendar
#
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REFRESH_TOKEN=your_refresh_token
# GOOGLE_REDIRECT_URI=http://localhost:5000

# ─── LINE Notify (ไม่บังคับ) ──────────────────────────────
# LINE_NOTIFY_TOKEN=your_line_notify_token
